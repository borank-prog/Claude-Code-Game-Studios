rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    function gangOwnerId(gangId) {
      let path = /databases/$(database)/documents/gangs/$(gangId);
      return existsAfter(path)
        ? (getAfter(path).data.ownerId is string ? getAfter(path).data.ownerId : '')
        : (
            exists(path) &&
            get(path).data.ownerId is string
              ? get(path).data.ownerId
              : ''
          );
    }
    function gangAcceptsOpenJoin(gangId) {
      let path = /databases/$(database)/documents/gangs/$(gangId);
      return existsAfter(path)
        ? (
            getAfter(path).data.inviteOnly != true &&
            getAfter(path).data.acceptJoinRequests != false
          )
        : (
            exists(path) &&
            get(path).data.inviteOnly != true &&
            get(path).data.acceptJoinRequests != false
          );
    }
    function hasGangInvite(gangId, uid) {
      let inviteId = gangId + "_" + uid;
      return exists(/databases/$(database)/documents/gang_invites/$(inviteId)) &&
        get(/databases/$(database)/documents/gang_invites/$(inviteId)).data.toUid == uid &&
        get(/databases/$(database)/documents/gang_invites/$(inviteId)).data.gangId == gangId &&
        (get(/databases/$(database)/documents/gang_invites/$(inviteId)).data.status == 'pending' ||
         get(/databases/$(database)/documents/gang_invites/$(inviteId)).data.status == 'accepted');
    }
    function canGangLeaderAssignUserToGang() {
      return request.resource.data.gangId is string &&
        request.resource.data.gangId != '' &&
        request.resource.data.gangRole is string &&
        request.resource.data.gangRole == 'Üye' &&
        gangOwnerId(request.resource.data.gangId) == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'gangId',
          'gangName',
          'gangRole',
          'updatedAt'
        ]);
    }
    function gangWarParticipantDocId(warId, uid) {
      return warId + "_" + uid;
    }
    function isGangWarParticipant(warId, uid) {
      let pid = gangWarParticipantDocId(warId, uid);
      let path = /databases/$(database)/documents/gang_war_participants/$(pid);
      return exists(path) &&
        get(path).data.warId == warId &&
        get(path).data.uid == uid &&
        get(path).data.status == 'active';
    }

    // ── User profiles (all game data, leaderboard, social, FCM) ──
    match /users/{uid} {
      allow read: if isLoggedIn();
      allow create: if isOwner(uid) &&
        request.resource.data.uid == uid &&
        request.resource.data.isBot != true;
      // Sensitive economy/combat fields are server-authoritative (Cloud Functions).
      allow update: if isLoggedIn() &&
        (
          (
            isOwner(uid) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'uid',
              'name',
              'displayName',
              'avatarId',
              'equippedWeaponId',
              'equippedKnifeId',
              'equippedArmorId',
              'equippedVehicleId',
              'combatWeaponId',
              'online',
              'updatedAt',
              'lastLoginEpoch',
              'gangId',
              'gangName',
              'gangRole',
              'fcmToken',
              'fcmUpdatedAt',
              'platform'
            ])
          ) ||
          canGangLeaderAssignUserToGang()
        );

      // Friends sub-collection
      match /friends/{friendId} {
        allow read: if isOwner(uid);
        allow write: if isLoggedIn() && (isOwner(uid) || isOwner(friendId));
      }

      // Event queue sub-collection
      match /event_queue/{eventId} {
        allow read, write: if isOwner(uid);
      }

      // Inbox sub-collection (notifications, war reports, invites)
      match /inbox/{messageId} {
        allow read: if isOwner(uid);
        // Client can only toggle local read state.
        allow update: if isOwner(uid) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isRead', 'status']);
        allow create, delete: if false;
      }
    }

    // ── Cloud saves ──
    match /user_saves/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── Friend requests ──
    match /friend_requests/{requestId} {
      allow read: if isLoggedIn() &&
        (resource.data.fromId == request.auth.uid ||
         resource.data.toId == request.auth.uid);
      allow create: if isLoggedIn() &&
        request.resource.data.fromId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if isLoggedIn() &&
        (resource.data.toId == request.auth.uid ||
         resource.data.fromId == request.auth.uid);
    }

    // ── Attacks ──
    match /attacks/{attackId} {
      allow read: if isLoggedIn() &&
        (resource.data.attackerId == request.auth.uid ||
         resource.data.targetId  == request.auth.uid);
      allow create: if false;
      allow update, delete: if false;
    }

    // ── Attack cooldowns ──
    match /attack_cooldowns/{docId} {
      allow read: if isLoggedIn();
      allow write: if false;
    }

    // ── Gangs ──
    match /gangs/{gangId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() &&
        request.resource.data.ownerId == request.auth.uid;
      // Only gang owner can update gang fields, or limited fields for others
      allow update: if isLoggedIn() && (
        resource.data.ownerId == request.auth.uid ||
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['totalPower', 'memberCount', 'vault', 'respectPoints', 'updatedAt']) &&
          request.resource.data.memberCount is int &&
          request.resource.data.memberCount >= 0 &&
          request.resource.data.memberCount <= 5 &&
          request.resource.data.totalPower is int &&
          request.resource.data.totalPower >= 0 &&
          request.resource.data.totalPower <= 500000 &&
          request.resource.data.vault is int &&
          request.resource.data.vault >= 0 &&
          request.resource.data.vault <= 100000000 &&
          request.resource.data.respectPoints is int &&
          request.resource.data.respectPoints >= 0 &&
          request.resource.data.respectPoints <= 100000000 &&
          request.resource.data.memberCount >= resource.data.memberCount - 1 &&
          request.resource.data.memberCount <= resource.data.memberCount + 1 &&
          request.resource.data.totalPower >= resource.data.totalPower - 50000 &&
          request.resource.data.totalPower <= resource.data.totalPower + 50000 &&
          request.resource.data.vault >= resource.data.vault &&
          request.resource.data.vault <= resource.data.vault + 500000 &&
          request.resource.data.respectPoints >= resource.data.respectPoints &&
          request.resource.data.respectPoints <= resource.data.respectPoints + 50000
        )
      );

      // Gang members
      match /members/{memberId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn() && (
          // Leader can add members (approve request/invite flow)
          gangOwnerId(gangId) == request.auth.uid ||
          // Player can only add self when gang is open OR has a valid invite
          (
            request.auth.uid == memberId &&
            request.resource.data.uid == memberId &&
            request.resource.data.role == 'Üye' &&
            (gangAcceptsOpenJoin(gangId) || hasGangInvite(gangId, memberId))
          )
        );
        // Member docs are controlled by leader to prevent role tampering.
        allow update: if isLoggedIn() && gangOwnerId(gangId) == request.auth.uid;
        // Leader can remove anyone; member can leave own gang.
        allow delete: if isLoggedIn() &&
          (gangOwnerId(gangId) == request.auth.uid || request.auth.uid == memberId);
      }

      // Contribution logs
      match /contributions/{contribId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn() &&
          request.resource.data.uid == request.auth.uid;
      }
    }

    // ── Gang raids ──
    match /gang_raids/{raidId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() &&
        request.resource.data.leaderId == request.auth.uid &&
        request.resource.data.members is list &&
        request.resource.data.members.size() == 1 &&
        request.resource.data.members[0] == request.auth.uid &&
        request.resource.data.status == 'waiting';
      allow update: if isLoggedIn() && (
        resource.data.leaderId == request.auth.uid ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberNames', 'updatedAt']) &&
          request.resource.data.members is list &&
          request.resource.data.members.size() <= 4 &&
          request.auth.uid in request.resource.data.members &&
          request.resource.data.leaderId == resource.data.leaderId &&
          request.resource.data.targetId == resource.data.targetId &&
          request.resource.data.status == resource.data.status
        )
      );
      allow delete: if false;
    }

    // ── Gang join requests (player -> leader) ──
    match /gang_join_requests/{requestId} {
      allow read: if isLoggedIn() &&
        (resource.data.fromId == request.auth.uid ||
         resource.data.leaderId == request.auth.uid);
      allow create: if isLoggedIn() &&
        request.resource.data.fromId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if isLoggedIn() && (
        // Leader approves/rejects
        resource.data.leaderId == request.auth.uid ||
        // Sender can cancel own pending request
        (resource.data.fromId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']))
      );
      allow delete: if false;
    }

    // ── Gang invites (leader -> player) ──
    match /gang_invites/{inviteId} {
      allow read: if isLoggedIn() &&
        (resource.data.toUid == request.auth.uid ||
         resource.data.leaderId == request.auth.uid);
      allow create: if isLoggedIn() &&
        request.resource.data.leaderId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if isLoggedIn() &&
        (resource.data.toUid == request.auth.uid ||
         resource.data.leaderId == request.auth.uid);
      allow delete: if false;
    }

    // ── Gang chat messages ──
    match /gang_chats/{gangId}/messages/{msgId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.type == 'text' &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() <= 500;
    }

    // ── Trade offers ──
    match /trade_offers/{offerId} {
      allow read: if isLoggedIn() &&
        (resource.data.fromId == request.auth.uid ||
         resource.data.toId == request.auth.uid);
      allow create: if isLoggedIn() &&
        request.resource.data.fromId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if isLoggedIn() &&
        (resource.data.toId == request.auth.uid ||
         resource.data.fromId == request.auth.uid) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status']);
      allow delete: if false;
    }

    // ── Gang leaderboard (read-only, written by Cloud Functions) ──
    match /gang_leaderboard/{gangId} {
      allow read: if isLoggedIn();
      allow write: if false;
    }

    // ── Gang wars (foundation) ──
    match /gang_wars/{warId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() &&
        request.resource.data.createdByUid == request.auth.uid &&
        request.resource.data.attackerGangId is string &&
        request.resource.data.defenderGangId is string &&
        request.resource.data.attackerGangId != request.resource.data.defenderGangId &&
        request.resource.data.status in ['recruiting', 'ready', 'active', 'resolved', 'cancelled'];
      allow update: if isLoggedIn() && (
        resource.data.createdByUid == request.auth.uid ||
        (
          isGangWarParticipant(warId, request.auth.uid) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status',
            'result',
            'winnerGangId',
            'attackerCount',
            'defenderCount',
            'attackerPowerSnapshot',
            'defenderPowerSnapshot',
            'startsAt',
            'endsAt',
            'resolvedAt',
            'updatedAt'
          ])
        )
      );
      allow delete: if false;
    }

    match /gang_war_participants/{participantId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.warId is string &&
        request.resource.data.warId != '' &&
        request.resource.data.status == 'active' &&
        participantId == gangWarParticipantDocId(
          request.resource.data.warId,
          request.auth.uid
        );
      allow update: if isLoggedIn() && (
        request.auth.uid == resource.data.uid ||
        (
          resource.data.warId is string &&
          resource.data.warId != '' &&
          exists(/databases/$(database)/documents/gang_wars/$(resource.data.warId)) &&
          get(/databases/$(database)/documents/gang_wars/$(resource.data.warId)).data.createdByUid == request.auth.uid
        )
      );
      allow delete: if false;
    }

    match /gang_war_events/{eventId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() &&
        request.resource.data.actorUid == request.auth.uid &&
        request.resource.data.warId is string &&
        request.resource.data.warId != '' &&
        isGangWarParticipant(request.resource.data.warId, request.auth.uid);
      allow update, delete: if false;
    }

    match /gang_war_reports/{reportId} {
      allow read: if isLoggedIn() &&
        resource.data.viewerUid == request.auth.uid;
      allow create: if isLoggedIn() &&
        request.resource.data.viewerUid == request.auth.uid &&
        request.resource.data.warId is string &&
        request.resource.data.warId != '' &&
        isGangWarParticipant(request.resource.data.warId, request.auth.uid);
      allow update, delete: if false;
    }
  }
}
