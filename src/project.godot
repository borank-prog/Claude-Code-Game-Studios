; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="CartelHood"
config/description="Mobil suc dunyasi RPG — sokaktan zirveye, cetenle birlikte."
run/main_scene="res://src/ui/screens/main_screen.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://assets/art/icon.png"

[autoload]

GameData="*res://src/core/game_data.gd"
EventBus="*res://src/core/event_bus.gd"
StaminaManager="*res://src/core/stamina_manager.gd"
EconomyManager="*res://src/economy/economy_manager.gd"
ItemDB="*res://src/data/item_database.gd"
ScreenManager="*res://src/ui/screen_manager.gd"
InventoryManager="*res://src/economy/inventory_manager.gd"
ShopSystem="*res://src/economy/shop_system.gd"
MissionSystem="*res://src/gameplay/mission_system.gd"
TerritoryManager="*res://src/gameplay/territory_manager.gd"
GangManager="*res://src/gameplay/gang_manager.gd"
GangWarManager="*res://src/gameplay/gang_war_manager.gd"
BuildingManager="*res://src/gameplay/building_manager.gd"
FirebaseAuth="*res://src/networking/firebase_auth.gd"
FirebaseFirestore="*res://src/networking/firebase_firestore.gd"
CloudSave="*res://src/networking/cloud_save_manager.gd"

[display]

window/size/viewport_width=430
window/size/viewport_height=932
window/handheld/orientation=1
window/stretch/mode="viewport"
window/stretch/aspect="expand"

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
